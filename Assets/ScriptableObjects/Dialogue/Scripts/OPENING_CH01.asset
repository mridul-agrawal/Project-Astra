%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f5916365cbfdcb549a23fd2a12e57125, type: 3}
  m_Name: OPENING_CH01
  m_EditorClassIdentifier: ProjectAstra.Core::ProjectAstra.Core.Dialogue.DialogueScript
  _scriptId: OPENING_CH01
  _nodes:
  - _nodeId: 0
    _speakerId: NARRATOR
    _expression: 0
    _portraitPosition: 3
    _text: Below the mountains, where the jungle keeps its oldest secrets, there
      was a village that asked little of the world.
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 1
    _speakerId: NARRATOR
    _expression: 0
    _portraitPosition: 3
    _text: And a girl who hunted its forests. She could read a trail like scripture,
      and loose an arrow before a deer thought to run.
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 2
    _speakerId: NARRATOR
    _expression: 0
    _portraitPosition: 3
    _text: This dusk, she tracked alone, the way she liked best.
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 3
    _speakerId: PROTAGONIST
    _expression: 0
    _portraitPosition: 0
    _text: Fresh tracks. Still soft at the edges.
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 4
    _speakerId: PROTAGONIST
    _expression: 0
    _portraitPosition: 0
    _text: "But these aren't deer. Not boar. \u2026Nothing I've ever tracked."
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 5
    _speakerId: PROTAGONIST
    _expression: 4
    _portraitPosition: 0
    _text: "Too deep. Clawed. And they don't wander like a beast \u2014 they go straight."
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
  - _nodeId: 6
    _speakerId: PROTAGONIST
    _expression: 0
    _portraitPosition: 0
    _text: "\u2026Straight for the village!"
    _textSpeedOverride: -1
    _autoAdvanceDelay: 0
    _fullScreenImage: {fileID: 0}
